{
    "manifest_version": 3,
    "name": "Site Analyser",
    "version": "2.1",
    "description": "This extension helps analyze website safety.",
    "permissions": ["tabs", "activeTab", "storage", "notifications", "webRequest",
    "webRequestBlocking", "<all_urls>"],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "Secure.png",
            "48": "Secure.png",
            "128": "Secure.png"
        }
    },
    "web_accessible_resources": [
        {
            "resources": ["Secure.png", "Warning.png", "Danger.png"],
            "matches": ["<all_urls>"]
        }
    ],
    "options_page": "reported.html"
}
