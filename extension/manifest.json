{
    "manifest_version": 3,
    "name": "Site Analyser",
    "version": "2.1",
    "description": "Analyzes website safety by checking HTTPS usage and allows phishing reporting.",
    "author": "xAI",
    "homepage_url": "https://x.ai",
    "permissions": [
        "tabs",
        "activeTab",
        "storage"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "Secure.png",
            "48": "Secure.png",
            "128": "Secure.png"
        }
    },
    "web_accessible_resources": [
        {
            "resources": [
                "Secure.png",
                "Warning.png",
                "Danger.png"
            ],
            "matches": ["<all_urls>"]
        }
    ],
    "options_page": "reported.html",
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self';"
    }
}